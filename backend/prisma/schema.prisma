generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  user
  admin
  seller
}
enum ItemType {
  product
  service
}
enum RequestStatus {
  pending
  approved
  rejected
}
model User {
  id                     String                 @id @default(uuid())
  name                   String
  email                  String                 @unique
  emailVerified          DateTime?              @map("email_verified")
  image                  String?
  phone                  String?
  password               String?
  role                   Role                 @default(user)
  banned                 Boolean                @default(false)
  banReason              String?                @map("ban_reason")
  banExpiresAt           DateTime?              @map("ban_expires_at")
  history                String                 @default("") @db.VarChar(400)
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  
  Product                Products[]
  Servicos               Servicos[]
  Comments               Comments[]
  Category               Category[]
  Favorite               Favorite[]
  sellerRequest          SellerRequest[]
  handledRequests        SellerRequest[] @relation("AdminHandledRequests")
}
model Products {
  id String @id @default(uuid())
  name String
  userId String
  description String
  price Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  categoryId String
  comments Comments[]
  products_images products_images[]

  category Category @relation(fields: [categoryId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
model Servicos {
  id String @id @default(uuid())
  name String
  userId String
  description String
  price Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  categoryId String
  comments Comments[]
  servicos_images servicos_images[]

  category Category @relation(fields: [categoryId], references: [id])
  user User @relation(fields: [userId], references: [id])
}
model Category {
  id String @id @default(uuid())
  name String
  description String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId String

  user User @relation(fields: [userId], references: [id])

  products Products[]
  servicos Servicos[]
}
model Comments {
  id String @id @default(uuid())
  comment String
  userId String
  productId String?
  serviceId String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  product Products? @relation(fields: [productId], references: [id])
  service Servicos? @relation(fields: [serviceId], references: [id])
}
model Favorite {
  id String @id @default(uuid())
  userId String
  itemId String
  itemType ItemType
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references:[id])

  @@index([userId], name: "favorite_user_idx")
  @@index([itemId, itemType], name: "favorite_item_idx")

  @@unique([userId, itemId, itemType], name: "favorite_unique")
}
model products_images {
  id String @id @default(uuid())
  productId String
  imageUrl String
  imageKey String
  position Int @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Products @relation(fields: [productId], references: [id])
}
model servicos_images {
  id String @id @default(uuid())
  serviceId String
  imageUrl String
  imageKey String
  position Int @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  service Servicos @relation(fields: [serviceId], references: [id])
}
model SellerRequest {
  id String @id @default(uuid())
  userId String
  storeName String
  description String
  phone String
  cpf String @unique
  status RequestStatus
  handleById String?
  handleAt DateTime?
  adminFeedBack String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sellerRequestImages SellerRequestImages[]

  user User @relation(fields: [userId], references: [id])
 handledByUser User? @relation("AdminHandledRequests", fields: [handleById], references: [id])


  @@index([userId], name: "seller_request_user_idx")
}
model SellerRequestImages {
  id String @id @default(uuid())
  sellerRequestId String
  imageKey String
  imageUrl String
  position Int @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sellerRequest SellerRequest @relation(fields: [sellerRequestId], references: [id])

  @@index([sellerRequestId], name: "seller_request_images_seller_request_idx")
}